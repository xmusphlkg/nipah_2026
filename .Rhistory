ts_city <- ts(df_city$暴发地区, start = c(start_year_recent, start_month_recent), frequency = 12)
# Use Holt-Winters method for forecasting
model_city_hw <- hw(ts_city, h = n_periods, seasonal = "multiplicative")
# Use Holt-Winters method for forecasting
model_city_hw <- hw(ts_city, h = n_periods, seasonal = "multiplicative")
df_forecast$Outbreak_City_Inbound_Volume <- as.numeric(model_city_hw$mean)
df_city$暴发地区
df_forecast$Other_India_Cities_Inbound_Volume <- as.numeric(model_city_hw$mean)
df_history
df_history$Other_India_Cities_Inbound_Volume <- df_city$其他印度城市
#####################################
## @Description: Risk Assessment of Nipah Virus Importation (Weighted & Visualized)
## @version: 2.0
## @Author: Li Kangguo
## @Date: 2026-01-29
#####################################
library(openxlsx)
library(tidyverse)
library(forecast)
library(patchwork)
# 1. Load Data
file_history <- "印度与全球入境流量统计.xlsx"
file_forecast <- "预测数据25年12月-26年5月.xlsx"
file_city <- "印度（城市）入中国客流16-25.xlsx"
df_history <- read.xlsx(file_history)
names(df_history) <- c("Time", "India_Inbound_Volume", "Global_Inbound_Volume")
df_forecast <- read.xlsx(file_forecast)
names(df_forecast) <- c("Time", "India_Inbound_Volume", "Global_Inbound_Volume")
df_city <- read.xlsx(file_city)[,3:5]
names(df_city) <- c("City", "Inbound_Volume", "Time")
df_city <- df_city |>
arrange(Time) |>
mutate(
City = ifelse(City %in% c('Kolkata'), '暴发地区', '其他印度城市'),
Year = as.numeric(substr(as.character(Time), 1, 4)),
Month = as.numeric(substr(as.character(Time), 5, 6)),
Date_Obj = as.Date(paste(Year, Month, "01", sep = "-"))
) |>
group_by(City, Date_Obj) |>
summarise(Inbound_Volume = sum(Inbound_Volume, na.rm = TRUE),
.groups = 'drop') |>
pivot_wider(names_from = City, values_from = Inbound_Volume)
df_history$Outbreak_City_Inbound_Volume <- df_city$暴发地区
df_history$Other_India_Cities_Inbound_Volume <- df_city$其他印度城市
# 1.1 Forecast BOTH India and Global Volumes (Strategy Update: Holt-Winters Seasonal)
# Filter for recent data (Post-2023) to capture post-COVID recovery trend
df_recent_train <- df_history
# Prepare Time Series Start Point
start_year_recent <- as.numeric(substr(as.character(df_recent_train[1, 1]), 1, 4))
start_month_recent <- as.numeric(substr(as.character(df_recent_train[1, 1]), 5, 6))
n_periods <- nrow(df_forecast)
# --- Forecast 1: India Inbound Volume ---
ts_india_recent <- ts(df_recent_train$India_Inbound_Volume, start = c(start_year_recent, start_month_recent), frequency = 12)
# Use Holt-Winters Seasonal Method (Multiplicative allows seasonality to grow with trend)
model_india_hw <- hw(ts_india_recent, h = n_periods, seasonal = "multiplicative")
df_forecast[, 2] <- as.numeric(model_india_hw$mean)
# --- Forecast 2: Global Inbound Volume ---
ts_global_recent <- ts(df_recent_train$Global_Inbound_Volume, start = c(start_year_recent, start_month_recent), frequency = 12)
# Use Holt-Winters Seasonal Method
model_global_hw <- hw(ts_global_recent, h = n_periods, seasonal = "multiplicative")
df_forecast[, 3] <- as.numeric(model_global_hw$mean)
# --- Forecast 3: City Level Inbound Volume ---
ts_city <- ts(df_city$暴发地区, start = c(start_year_recent, start_month_recent), frequency = 12)
# Use Holt-Winters method for forecasting
model_city_hw <- hw(ts_city, h = n_periods, seasonal = "multiplicative")
df_forecast$Outbreak_City_Inbound_Volume <- as.numeric(model_city_hw$mean)
# --- Forecast 4: City Level Inbound Volume ---
ts_city <- ts(df_city$其他印度城市, start = c(start_year_recent, start_month_recent), frequency = 12)
model_city_hw <- hw(ts_city, h = n_periods, seasonal = "multiplicative")
df_forecast$Other_India_Cities_Inbound_Volume <- as.numeric(model_city_hw$mean)
df_combined <- bind_rows(df_history, df_forecast) |>
mutate(Time = as.character(Time),
Year = as.numeric(substr(Time, 1, 4)),
Month = as.numeric(substr(Time, 5, 6)),
Date_Obj = as.Date(paste(Year, Month, "01", sep = "-")))
df_combined
fig1 <- df_combined |>
select(Date_Obj, India_Inbound_Volume, Global_Inbound_Volume, Outbreak_City_Inbound_Volume, Other_India_Cities_Inbound_Volume) |>
pivot_longer(cols = contains("Inbound_Volume"),
names_to = "Region", values_to = "Volume") |>
mutate(Region = recode(Region,
"Outbreak_City_Inbound_Volume" = "暴发地区",
"Other_India_Cities_Inbound_Volume" = "其他印度城市",
"India_Inbound_Volume" = "印度",
"Global_Inbound_Volume" = "全球"),
Region = factor(Region, levels = c("全球", "印度", "加尔各答", "其他印度城市"))) |>
ggplot(aes(x = Date_Obj, y = Volume, color = Region)) +
geom_vline(xintercept = as.numeric(as.Date("2025-12-01")),
linetype = "dashed",
color = "red") +
geom_line(show.legend = F) +
scale_y_continuous(labels = comma,
expand = expansion(mult = c(0, 0.15)),
limits = c(0, NA)) +
facet_wrap(~Region, ncol = 3, scales = "free_y") +
labs(x = NULL,
y = "入境流量 (人次)",
title = "入境人流变化",
caption = "红色虚线表示预测起始时间点，2025年12月至2026年5月为模型预测结果")
fig1
