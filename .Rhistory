df_combined
df_combined <- df_combined |>
mutate(
# Seasonal Weight: 1.5 for High Risk Season (Dec-May), 1.0 for Low Risk Season
Seasonal_Weight = ifelse(Month %in% c(12, 1, 2, 3, 4, 5), 1.5, 1.0),
# Location Weighting Logic:
# Outbreak Region (Kolkata): Assigned significantly higher weight (e.g., 10) due to confirmed cases.
# Rest of India: Treated as baseline risk (Weight = 1), similar to global background surveillance.
# Formula: Risk = (Outbreak_Volume * High_Weight + Rest_Volume * Baseline_Weight) * Seasonal_Factor
Weighted_Score = (City_Inbound_Volume * 10 + (India_Inbound_Volume - City_Inbound_Volume) * 1) * Seasonal_Weight)
df_combined <- df_combined |>
mutate(
# Seasonal Weight: 1.5 for High Risk Season (Dec-May), 1.0 for Low Risk Season
Seasonal_Weight = ifelse(Month %in% c(12, 1, 2, 3, 4, 5), 1.5, 1.0),
# Location Weighting Logic:
# Outbreak Region (Kolkata): Assigned significantly higher weight (e.g., 10) due to confirmed cases.
# Rest of India: Treated as baseline risk (Weight = 1), similar to global background surveillance.
# Formula: Risk = (Outbreak_Volume * High_Weight + Rest_Volume * Baseline_Weight) * Seasonal_Factor
Weighted_Score = (Outbreak_City_Inbound_Volume * 10 + Other_India_Cities_Inbound_Volume * 1) * Seasonal_Weight)
probs <- c(0.2, 0.4, 0.6, 0.8)
thresholds <- quantile(df_combined$Weighted_Score, probs = probs, na.rm = TRUE)
df_combined <- df_combined |>
mutate(
Risk_Level = case_when(
Weighted_Score <= thresholds[1] ~ "Level 1: Very Low",
Weighted_Score <= thresholds[2] ~ "Level 2: Low",
Weighted_Score <= thresholds[3] ~ "Level 3: Moderate",
Weighted_Score <= thresholds[4] ~ "Level 4: High",
TRUE ~ "Level 5: Critical"
)
)
# Convert Risk_Level to factor for ordered plotting
df_combined$Risk_Level <- factor(df_combined$Risk_Level, levels = c(
"Level 1: Very Low", "Level 2: Low", "Level 3: Moderate", "Level 4: High", "Level 5: Critical"
))
# Plot 1: Overall Trend with Risk Levels
# Highlighting the curve with color mapped to Risk Level
p1 <- ggplot(df_combined, aes(x = Date_Obj, y = India_Inbound_Volume)) +
geom_line(color = "gray70") +
geom_point(aes(color = Risk_Level, size = Seasonal_Weight)) +
scale_color_brewer(palette = "RdYlGn", direction = -1) + # Red for High, Green for Low
labs(
title = "Trend of India Inbound Volume & Nipah Importation Risk",
subtitle = "Size indicates Seasonal Weight; Color indicates Risk Level (Weighted)",
x = "Date",
y = "Inbound Volume (Person)",
color = "Risk Level",
size = "Seasonal Weight"
) +
theme_minimal() +
theme(legend.position = "bottom")
# Plot 2: Forecast Period Risk (Bar Chart)
p2 <- ggplot(df_recent, aes(x = as.factor(Time), y = Weighted_Score, fill = Risk_Level)) +
geom_bar(stat = "identity") +
geom_text(aes(label = Risk_Level), vjust = -0.5, size = 3) +
scale_fill_brewer(palette = "RdYlGn", direction = -1) +
labs(
title = "Forecasted Risk Assessment (Dec 2025 - May 2026)",
subtitle = "Based on Volume x Seasonal Weight (1.5 for Winter/Spring)",
x = "Time Code",
y = "Weighted Risk Score"
) +
theme_minimal() +
theme(legend.position = "none") # Hide legend as labels are on bars
